{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=RecruitmentDb_main;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "RecruitSaas",
    "Audience": "RecruitSaasUsers"
  },
  "AppSettings": {
    "BaseUrl": "https://localhost:5001"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "EmailSettings": {
    "SmtpHost": "smtp-relay.brevo.com",
    "SmtpPort": 587,
    "SmtpUseSsl": true,
    "SmtpUsername": "YOUR_BREVO_SMTP_USERNAME",
    "SmtpPassword": "YOUR_BREVO_SMTP_PASSWORD",
    "FromEmail": "your-email@example.com",
    "FromName": "RecruitSaaS",
    "FrontendBaseUrl": "http://localhost:5173"
  },
  "CloudinarySettings": {
    "CloudName": "YOUR_CLOUDINARY_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "Frontend": {
    "Url": "http://localhost:5173"
  }
}
